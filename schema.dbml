// ==========================================
// DATA WAREHOUSE - RECRUITMENT MARKET
// STAR SCHEMA DESIGN (FULL VERSION)
// ==========================================

// --- FACT TABLE ---
Table fact_job_posting {
  job_key serial [pk, note: "Khóa chính tự tăng"]
  company_key int [note: "FK -> dim_company"]
  location_key int [note: "FK -> dim_location"]
  job_info_key int [note: "FK -> dim_job_info"]
  benefit_key int [note: "FK -> dim_benefits"]
  posted_date_key int [note: "FK -> dim_date (YYYYMMDD)"]
  due_date_key int [note: "FK -> dim_date (YYYYMMDD)"]
  
  min_salary_vnd numeric [note: "Ví dụ: 12000000"]
  max_salary_vnd numeric [note: "Ví dụ: 25000000"]
  is_salary_negotiable boolean [note: "True nếu 'Cạnh tranh'"]
  min_experience_years numeric [note: "Ví dụ: 2"]
  max_experience_years numeric [note: "Ví dụ: 4"]
}

// --- DIMENSION TABLES ---

Table dim_company {
  company_key serial [pk]
  company_name varchar [note: "Tên công ty"]
}

Table dim_location {
  location_key serial [pk]
  raw_address text [note: "Địa chỉ gốc cào về"]
  city varchar [note: "Tỉnh/Thành phố"]
  district varchar [note: "Quận/Huyện"]
}

Table dim_job_info {
  job_info_key serial [pk]
  job_url varchar [note: "Link bài đăng gốc"]
  title varchar [note: "Tiêu đề công việc"]
  job_category varchar [note: "Ngành nghề (CNTT, Tài chính...)"]
  employment_type varchar [note: "Loại hợp đồng (Fulltime, Parttime)"]
  position_level varchar [note: "Cấp bậc (Nhân viên, Quản lý)"]
  education_level varchar [note: "Yêu cầu bằng cấp (Đại học, Cao đẳng)"]
  job_description text [note: "Mô tả công việc"]
  job_requirements text [note: "Yêu cầu công việc"]
}

Table dim_benefits {
  benefit_key serial [pk]
  raw_benefits_list jsonb [note: "Lưu mảng JSON gốc để backup"]
  has_laptop boolean [note: "Cờ: Có cấp Laptop không?"]
  has_insurance boolean [note: "Cờ: Có bảo hiểm không?"]
  has_annual_leave boolean [note: "Cờ: Có phép năm không?"]
  has_training boolean [note: "Cờ: Có đào tạo không?"]
  has_travel boolean [note: "Cờ: Có du lịch không?"]
}

Table dim_date {
  date_key int [pk, note: "Định dạng YYYYMMDD"]
  full_date date
  day int
  month int
  year int
  quarter int
  day_of_week varchar
}

Table dim_skill {
  skill_key serial [pk, note: "Khóa chính"]
  skill_name varchar [note: "Tên kỹ năng (vd: Python, SQL, PyTorch)"]
  skill_category varchar [note: "Phân loại (vd: Ngôn ngữ lập trình, Database, Cloud)"]
}

// --- BRIDGE TABLES ---

// Bảng cầu nối (Bridge Table) giữa Fact và Dim_Skill để giải quyết quan hệ N:N
Table bridge_job_skill {
  job_key int [note: "FK -> fact_job_posting"]
  skill_key int [note: "FK -> dim_skill"]
  weight numeric [note: "Mức độ quan trọng (Must-have = 1, Nice-to-have = 0.5)"]
  
  indexes {
    (job_key, skill_key) [pk] // Composite Primary Key
  }
}

// --- RELATIONSHIPS (FOREIGN KEYS) ---

Ref: fact_job_posting.company_key > dim_company.company_key
Ref: fact_job_posting.location_key > dim_location.location_key
Ref: fact_job_posting.job_info_key > dim_job_info.job_info_key
Ref: fact_job_posting.benefit_key > dim_benefits.benefit_key
Ref: fact_job_posting.posted_date_key > dim_date.date_key
Ref: fact_job_posting.due_date_key > dim_date.date_key

Ref: bridge_job_skill.job_key > fact_job_posting.job_key
Ref: bridge_job_skill.skill_key > dim_skill.skill_key